{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/projects/[projectId]",
      "regex": "^/api/projects/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId"
      },
      "namedRegex": "^/api/projects/(?<nxtPprojectId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/[projectId]",
      "regex": "^/dashboard/([^/]+?)(?:/)?$",
